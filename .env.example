# Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values

# Supabase Configuration (Pre-configured)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Stripe Configuration (Get from https://dashboard.stripe.com/apikeys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# App Configuration
VITE_APP_ID=25a44123a6
VITE_APP_NAME=Property Management System
VITE_APP_VERSION=1.0.0

# Optional: Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_MODE=false
# Stripe-backed payment surface. Leave "false" until the backend exposes
# stripe_customer_id on /api/v1/users/me — otherwise the UI passes a
# placeholder customer id to Stripe.
VITE_PAYMENTS_ENABLED=false
# MFA enrollment surface. Leave "false" until the backend issues TOTP
# secrets via CSPRNG and persists them per-user.
VITE_MFA_ENABLED=false

# LeaseFi Backend API
# Routed through the Vite dev proxy to /api/v1 in development
VITE_BACKEND_URL=https://your-backend-api-url

# CSPR.cloud API (get free key at https://console.cspr.cloud)
VITE_CSPR_CLOUD_API_KEY=your_cspr_cloud_api_key_here

# Casper Network
VITE_CASPER_NETWORK=casper-test
VITE_CASPER_RPC_URL=https://node.testnet.casper.network/rpc
VITE_CASPER_EXPLORER_URL=https://testnet.cspr.live

# ICO Contract Addresses (Testnet) — REQUIRED, app will throw on startup if missing
VITE_ICO_CONTRACT_HASH=hash-your_ico_contract_hash_here
VITE_ICO_PACKAGE_HASH=hash-your_ico_package_hash_here
VITE_BIG_TOKEN_CONTRACT_HASH=hash-f7d94fd8670fdc69aabd07c214ab8d52c3fc1fd839f0cc7713e1574cdfd899ec
VITE_TREASURY_CONTRACT_HASH=hash-your_treasury_contract_hash_here
VITE_VESTING_PACKAGE_HASH=hash-your_vesting_package_hash_here
VITE_STAKING_CONTRACT_HASH=hash-8e0336540c15073cb2e181d01615dde8e1cd405c51526b8a9b985b12c1f5e345
# Package hashes — used for approve() transactions
VITE_USDC_CONTRACT_HASH=hash-7f06f66426f18ca8d3b8df69f977a54554d39fda43ebe942fd22ece0d20235bd
VITE_USDT_CONTRACT_HASH=hash-7c902e8a111b3116e00c7507138b92b83f96b29be98aa95247928583720e297a
# Contract instance hashes — used for state queries (allowance, balance)
VITE_USDC_CONTRACT_INSTANCE_HASH=hash-your_usdc_contract_instance_hash_here
VITE_USDT_CONTRACT_INSTANCE_HASH=hash-your_usdt_contract_instance_hash_here

# CSPR.cloud WebSocket (streaming endpoint)
VITE_CSPR_CLOUD_WS_URL=wss://streaming.cspr.cloud

# CSPR.click App ID (register at https://cspr.click)
VITE_CSPRCLICK_APP_ID=csprclick-template

# Email (Resend) — server-side only, NOT prefixed with VITE_
# Set in Vercel dashboard: Settings → Environment Variables
RESEND_API_KEY=your_resend_api_key_here

# CORS — server-side only. Set in Vercel dashboard for Production.
# Leave unset locally to allow all origins (*)
ALLOWED_ORIGIN=https://your-production-domain.com