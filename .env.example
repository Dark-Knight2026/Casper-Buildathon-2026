# Database
DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres

# Auth
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Server
RUST_LOG=debug
PORT=8080
CORS_ORIGIN=http://localhost:8080

# Redis
REDIS_URL=redis://localhost:6379

# CSPR.cloud API (Casper Network indexer)
CSPR_CLOUD_API_TOKEN=your-cspr-cloud-api-token
CSPR_CLOUD_REST_URL=https://api.testnet.cspr.cloud
CSPR_CLOUD_WSS_URL=wss://streaming.testnet.cspr.cloud/contract-events
CASPER_NODE_RPC_URL=https://node.testnet.cspr.cloud/rpc

# Indexer tuning (optional, defaults shown)
#BACKFILL_RATE_LIMIT_MS=200
#WSS_RECONNECT_DELAY_MS=1000

# Casper contract package hashes (hex, no prefix)
CONTRACT_USDC=7f06f66426f18ca8d3b8df69f977a54554d39fda43ebe942fd22ece0d20235bd
CONTRACT_USDT=7c902e8a111b3116e00c7507138b92b83f96b29be98aa95247928583720e297a
CONTRACT_BIG=f7d94fd8670fdc69aabd07c214ab8d52c3fc1fd839f0cc7713e1574cdfd899ec
CONTRACT_TREASURY=04d0c23574c3c89be4cac153918327a3cc9c7bd24bc5a568d41ae5854b6e1ea2
CONTRACT_ICO=15d21005589e2f851a53c2ada9c6fbf8e870d03c4facc99864310fff2ec7cffb
#CONTRACT_LEASE=...
#CONTRACT_ESCROW=...
#CONTRACT_NFT=...
#CONTRACT_ROLES=...
CONTRACT_VESTING=d0e207b378820b29ff3d801cc6bc93dc6be5affc30f6be30cb1e82d7552e03b1
CONTRACT_STAKING=8e0336540c15073cb2e181d01615dde8e1cd405c51526b8a9b985b12c1f5e345

# ICO fallback (used when ico_schedules table is empty)
#ICO_PRICE_USD=0.50
#ICO_TOTAL_ALLOCATION=500000000000000000000000000

# Start blocks for indexer (defaults to 0 if not specified)
START_BLOCK_CONTRACT_USDC=6772391
START_BLOCK_CONTRACT_USDT=6772387
START_BLOCK_CONTRACT_BIG=6772953
START_BLOCK_CONTRACT_TREASURY=6765013
START_BLOCK_CONTRACT_ICO=7205878
START_BLOCK_CONTRACT_VESTING=7204848
#START_BLOCK_CONTRACT_STAKING=0

# Casper testnet secret key (for manual testnet tests)
CASPER_SECRET_KEY=/path/to/your/secret_key.pem
