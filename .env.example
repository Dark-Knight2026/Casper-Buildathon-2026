# ==============================================================================
# LeaseFi Backend Configuration
# ==============================================================================
# Copy this file to .env and fill in the values for your environment.

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
SQLX_OFFLINE=true
DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres

# ------------------------------------------------------------------------------
# Authentication (JWT)
# ------------------------------------------------------------------------------
# Minimum 64 bytes for HS256 security; generate with: openssl rand -base64 64
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-sixty-four-characters-long-for-HS256-security!

# Auth cookies are HttpOnly+SameSite=Strict regardless of this flag.
# Set to `true` in production/staging (HTTPS) so the browser refuses to send
# the cookie over plaintext HTTP. Keep `false` in local dev (HTTP localhost):
# with `Secure=true` on plain HTTP the browser silently drops the cookie and
# the auth flow appears broken.
COOKIE_SECURE=false

# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------
RUST_LOG=debug
PORT=8080
CORS_ORIGIN=http://localhost:8080
# Public base URL of the frontend, used to build links in transactional emails
# (e.g. the verify-email link: ${FRONTEND_URL}/verify-email?token=...).
# Defaults to http://localhost:3000 when unset.
FRONTEND_URL=http://localhost:3000

# Per-user cap on email-change requests within the rolling 24h window.
# Raise for staging or integration runs that need to exercise the flow more
# than 3 times per day. Must be >= 1; 0 would lock every user out.
#EMAIL_CHANGE_MAX_ATTEMPTS=3

# Outer cap (MiB) for any single request body, applied by both nginx and axum.
# Per-handler limits cut further (e.g. avatar uploads cap at MAX_AVATAR_BYTES =
# 5 MiB inside the handler). The outer ceiling needs ~3 MiB of multipart
# headroom above the largest per-handler cap so multer can stream cleanly and
# the documented 413 contract fires from axum, not from nginx as an HTML page.
# Raise when adding new large-upload endpoints (e.g. property images).
REQUEST_BODY_LIMIT_MB=8

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# Media Storage (S3-compatible: AWS S3, Cloudflare R2, MinIO)
# ------------------------------------------------------------------------------
# Avatar and other media-blob uploads. Local dev defaults below point at
# the MinIO container started by `make env-up` (port 9000, bucket created
# by `minio-init`). Comment the whole S3_* block to fall back to
# `StubMediaStorage`: uploads are logged (no real persistence) and image
# keys (`avatars/...`) return a `data:image/svg+xml` placeholder so the
# frontend renders something visible. Production MUST configure the full
# S3_* block - missing S3_REGION/ENDPOINT/ACCESS_KEY/SECRET_KEY while
# S3_BUCKET is set is a fail-fast error at startup.
S3_BUCKET=leasefi-media
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=YOUR_ACCESS_KEY_HERE
S3_SECRET_KEY=YOUR_SECRET_KEY_HERE
# Optional. Defaults to ${S3_ENDPOINT}/${S3_BUCKET} (path-style URL), which is
# correct for MinIO and AWS path-style. Virtual-hosted-style buckets
# (`{bucket}.s3.{region}.amazonaws.com`) MUST set this explicitly.
#S3_PUBLIC_URL_BASE=http://localhost:9000/leasefi-media

# ------------------------------------------------------------------------------
# Email (Postmark transactional mailer)
# ------------------------------------------------------------------------------
# POSTMARK_SERVER_TOKEN is the gate: when set, the Postmark-backed mailer and
# the email retry-queue worker are enabled, and POSTMARK_FROM_EMAIL is required.
# POSTMARK_FROM_EMAIL must be a *verified* Postmark sender signature - an
# unverified address turns every send into a permanent failure. When the token
# is unset, bootstrap falls back to LoggingEmailSender: emails are logged, not
# delivered, and the worker is not spawned. Leave both commented for local dev.
#POSTMARK_SERVER_TOKEN=your-postmark-server-token
#POSTMARK_FROM_EMAIL=noreply@yourdomain.com

# ------------------------------------------------------------------------------
# Bootstrap Admin (one-shot, consumed by `cargo run --bin bootstrap_admin`)
# ------------------------------------------------------------------------------
# BOOTSTRAP_ADMIN_EMAIL is the gate: if empty/unset, the binary logs "skipped"
# and exits successfully. FIRST/LAST name are optional (default: Platform/Admin).
# On success the binary prints a 10-minute bootstrap-login token to stdout.
#BOOTSTRAP_ADMIN_EMAIL=admin@example.com
#BOOTSTRAP_ADMIN_FIRST_NAME=Platform
#BOOTSTRAP_ADMIN_LAST_NAME=Admin

# ------------------------------------------------------------------------------
# CSPR.cloud API (Casper Network indexer)
# ------------------------------------------------------------------------------
CSPR_CLOUD_API_TOKEN=your-cspr-cloud-api-token
CSPR_CLOUD_REST_URL=https://api.testnet.cspr.cloud
CSPR_CLOUD_WSS_URL=wss://streaming.testnet.cspr.cloud/contract-events
# Required for CES event backfill via node RPC (provided by CSPR.cloud or self-hosted node)
CASPER_NODE_RPC_URL=https://node.testnet.cspr.cloud/rpc

# Indexer tuning (optional, defaults shown)
#BACKFILL_RATE_LIMIT_MS=200
#WSS_RECONNECT_DELAY_MS=1000

# ------------------------------------------------------------------------------
