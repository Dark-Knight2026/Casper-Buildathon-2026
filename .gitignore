# Rust build artifacts
target/
**/*.rs.bk

# Build artifacts
*.o
*.a
*.dylib
*.dll
*.exe

# Secrets
.secrets/
.env
.env.*
!.env.example

# IDE & editors
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs
*.log

# Claude artifacts
.claude/
CLAUDE.md
.mcp.json

# Secrets directory: hyphenated files contain sensitive credentials
# Files like secret/-iron.sh, secret/-api_keys.sh are gitignored via -* pattern
# secret/readme.md (documentation) is tracked - no hyphen prefix
-*

# Catch-all for dot-files/dirs not explicitly allowed above (subsumes .DS_Store, .idea/, .vscode/ etc.)
.*
!.github/
!.secret/

# Terraform
**/.terraform/
**/.terraform.lock.hcl
**/*.tfstate
**/*.tfstate.backup

# Database backups (NEVER commit)
backups/
*_backup*.db
*.db.backup
*.bak
*.orig
