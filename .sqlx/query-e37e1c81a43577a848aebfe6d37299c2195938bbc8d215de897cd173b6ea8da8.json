  "query": "\n            SELECT\n                a.monthly_income::float8 AS \"monthly_income!\",\n                a.employment_length,\n                a.reference2_name,\n                (l.terms->>'rentMonthly')::float8 AS rent_monthly\n            FROM rental_applications a\n            LEFT JOIN listings l ON l.id = a.listing_id\n            WHERE a.id = $1 AND a.landlord_id = $2\n        ",
