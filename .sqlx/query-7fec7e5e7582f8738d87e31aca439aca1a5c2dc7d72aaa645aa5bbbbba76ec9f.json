  "query": "\n            SELECT f.listing_id, f.created_at\n            FROM favorites f\n            JOIN listings l ON l.id = f.listing_id AND l.deleted_at IS NULL\n            WHERE f.user_id = $1\n            ORDER BY f.created_at DESC\n            LIMIT $2 OFFSET $3\n        ",
