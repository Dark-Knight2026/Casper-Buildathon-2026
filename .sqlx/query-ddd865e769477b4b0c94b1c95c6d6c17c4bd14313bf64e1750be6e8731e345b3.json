{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                event_type AS \"event_type!\",\n                amount AS \"amount!\",\n                event_timestamp AS \"event_timestamp!\",\n                transaction_hash AS \"transaction_hash!\"\n            FROM staking_events\n            WHERE staker_address = $1\n              AND event_type IN ('unstake', 'withdraw')\n            ORDER BY event_timestamp DESC\n            LIMIT 200\n        ",
