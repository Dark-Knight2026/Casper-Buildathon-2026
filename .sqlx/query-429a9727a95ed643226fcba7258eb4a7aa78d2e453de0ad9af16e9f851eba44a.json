  "query": "\n            SELECT\n                user_id,\n                user_email,\n                user_role,\n                action,\n                resource_type,\n                resource_id,\n                new_values,\n                status,\n                request_method,\n                request_path,\n                ip_address::text AS ip_text,\n                user_agent\n            FROM audit_logs\n            WHERE user_id = $1 AND action = 'verify_email'\n            ORDER BY created_at DESC\n            LIMIT 1\n        ",
