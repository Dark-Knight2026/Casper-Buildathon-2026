  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                rt.id,\n                rt.user_id,\n                rt.family_id,\n                rt.expires_at,\n                rt.revoked_at,\n                u.role,\n                u.verification_level\n            FROM refresh_tokens rt\n            JOIN users u ON u.id = rt.user_id\n            WHERE rt.token_hash = $1\n            FOR UPDATE OF rt\n        ",
