{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT u.id, u.role, u.verification_level, u.status\n                FROM users u\n                JOIN wallet_connections wc ON wc.user_id = u.id\n                WHERE wc.wallet_address = $1\n                  AND u.deleted_at IS NULL\n                LIMIT 1\n            ",
