  "query": "\n            INSERT INTO listing_media (listing_id, url, cid, position)\n            VALUES (\n                $1, $2, $3,\n                (SELECT COALESCE(MAX(position) + 1, 0)\n                 FROM listing_media WHERE listing_id = $1)\n            )\n            RETURNING id, listing_id, url, cid, position, moderation_status\n        ",
