  "query": "\n            SELECT id, listing_id, url, cid, position, moderation_status\n            FROM listing_media\n            WHERE listing_id = ANY($1)\n              AND (NOT $2::bool OR moderation_status = 'approved')\n            ORDER BY position ASC\n        ",
