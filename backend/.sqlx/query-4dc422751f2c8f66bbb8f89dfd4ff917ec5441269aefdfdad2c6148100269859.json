  "query": "\n            SELECT\n                id, listing_id, user_id, landlord_id, viewing_date,\n                viewing_time, status, created_at, updated_at\n            FROM viewings\n            WHERE listing_id = $1\n            ORDER BY created_at DESC\n            LIMIT $2 OFFSET $3\n        ",
