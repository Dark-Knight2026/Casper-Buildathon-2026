  "query": "\n            UPDATE listings\n            SET\n                authority_tier = CASE WHEN authority_tier = 'T0' THEN 'T1'\n                                      ELSE authority_tier END,\n                managed_by_pm = managed_by_pm OR $2\n            WHERE id = $1\n            RETURNING identity_verified, authority_tier, fair_housing_cleared,\n                      managed_by_pm\n        ",
