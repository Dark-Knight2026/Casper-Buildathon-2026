# Production Environment Variables for Edge Functions
# Set these using: supabase secrets set --env-file .env.production

# Supabase (Auto-available in edge functions)
SUPABASE_URL=https://mkvqnefrlgiqzrtpfakf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
APP_25a44123a6_STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
APP_25a44123a6_STRIPE_FREE_PRICE_ID=price_your_free_tier_id
APP_25a44123a6_STRIPE_PRO_PRICE_ID=price_your_pro_tier_id
APP_25a44123a6_STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_tier_id

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourpropertyapp.com

# Optional: Third-party API Keys
# OPENAI_API_KEY=sk-your-openai-key (if using AI features)
# TWILIO_ACCOUNT_SID=your-twilio-sid (if using SMS)
# TWILIO_AUTH_TOKEN=your-twilio-token

# ─────────────────────────────────────────────────────────────
# Frontend build variables — set in Vercel dashboard:
#   Project → Settings → Environment Variables (Target: Production)
# These are NOT passed via "supabase secrets set"; they must be
# configured in Vercel so that "vite build" can inline them.
# ─────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://mkvqnefrlgiqzrtpfakf.supabase.co
VITE_SUPABASE_ANON_KEY=# required: production anon key from Supabase dashboard

VITE_STRIPE_PUBLISHABLE_KEY=pk_live_# required: live publishable key

# LeaseFi Backend API
VITE_BACKEND_URL=# required: production backend API URL

# Vercel proxy security — restricts CORS for /api/cspr-cloud and /api/casper-rpc
# Set to your deployed app origin (no trailing slash). Falls back to * if unset.
ALLOWED_ORIGIN=https://your-leasefi-domain.com

# CSPR.cloud (get key at https://console.cspr.cloud)
# CSPR_CLOUD_API_KEY  — server-side proxy credential (Vercel env var, no VITE_ prefix).
#   Used by api/cspr-cloud.ts and api/casper-rpc.ts. Must be set explicitly so the
#   proxy never falls through to the VITE_ browser key below.
# VITE_CSPR_CLOUD_API_KEY — browser-side key for WebSocket streaming (inlined at build).
#   In a single-key setup both may share the same value, but both must be set.
CSPR_CLOUD_API_KEY=# required: server-side proxy credential (set in Vercel dashboard)
VITE_CSPR_CLOUD_API_KEY=# required: browser WebSocket key (inlined at build time)
VITE_CSPR_CLOUD_WS_URL=wss://streaming.cspr.cloud

# Casper Mainnet
VITE_CASPER_NETWORK=casper
VITE_CASPER_RPC_URL=https://node.mainnet.casper.network/rpc
VITE_CASPER_EXPLORER_URL=https://cspr.live

# ICO Contract Addresses (Mainnet) — app throws on startup if missing
VITE_ICO_CONTRACT_HASH=# required: mainnet ICO contract hash
VITE_ICO_PACKAGE_HASH=# required: mainnet ICO package hash
VITE_BIG_TOKEN_CONTRACT_HASH=hash-f7d94fd8670fdc69aabd07c214ab8d52c3fc1fd839f0cc7713e1574cdfd899ec
VITE_TREASURY_CONTRACT_HASH=# required: mainnet treasury contract hash
VITE_VESTING_PACKAGE_HASH=hash-d0e207b378820b29ff3d801cc6bc93dc6be5affc30f6be30cb1e82d7552e03b1
VITE_STAKING_CONTRACT_HASH=# required: mainnet staking contract hash
VITE_USDC_CONTRACT_HASH=hash-7f06f66426f18ca8d3b8df69f977a54554d39fda43ebe942fd22ece0d20235bd
VITE_USDT_CONTRACT_HASH=hash-7c902e8a111b3116e00c7507138b92b83f96b29be98aa95247928583720e297a
# Contract instance hashes — used for state queries (allowance, balance)
VITE_USDC_CONTRACT_INSTANCE_HASH=# required: mainnet USDC contract instance hash
VITE_USDT_CONTRACT_INSTANCE_HASH=# required: mainnet USDT contract instance hash

# CSPR.click App ID (register at https://cspr.click)
VITE_CSPRCLICK_APP_ID=# required: production app ID

VITE_APP_ID=25a44123a6
VITE_APP_NAME=Property Management System
VITE_APP_VERSION=1.0.0

VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG_MODE=false
# Flip to "true" once /api/v1/users/me returns stripe_customer_id.
VITE_PAYMENTS_ENABLED=false